# ───────────────────────────────────────────────
# PartnerRadar — environment variables
# Copy this file to .env (never commit .env).
# For Railway prod, set each in the project dashboard.
# ───────────────────────────────────────────────

# ── Core ──────────────────────────────────────
NODE_ENV=development

# Postgres (Railway prod, Docker Compose locally)
DATABASE_URL=postgresql://partnerradar:partnerradar@localhost:5432/partnerradar?schema=public

# NextAuth (Phase 1)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# AES-256-GCM key for encrypting OAuth/CalDAV tokens at rest
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-random-32-char-secret

# ── AI (Phase 7) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Phase 3 invites + Phase 7 drafts) ──
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=PartnerRadar <info@RoofTechnologies.com>

# ── SMS (Phase 7) ─────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...

# ── Google Maps (Phases 8 + 9) ────────────────
# Needs: Places API, Directions API, Geocoding API enabled
GOOGLE_MAPS_API_KEY=AIza...

# ── Cloudflare R2 (Phase 2 files + Phase 6 receipts) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=partnerradar-files
R2_PUBLIC_URL=https://files.partnerradar.app

# ── Upstash Redis (rate limiting) ─────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Inngest (background jobs, Phase 4+) ──────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Storm Cloud integration (Phase 5) ────────
# "mock" uses dev-data/storm-mock.json; "real" hits STORM_API_URL
STORM_API_MODE=mock
STORM_API_URL=
STORM_API_KEY=

# ── Observability ────────────────────────────
SENTRY_DSN=

# ── Expo public vars (exposed to mobile client) ──
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Event Tracking ───────────────────────────
# Quiet hours (24h clock, local to partner market). Defaults 8–20.
QUIET_HOURS_START=8
QUIET_HOURS_END=20

# ── Marketing Wizard ─────────────────────────
# "embedded" (inside PartnerRadar) or "standalone" (Stripe-billed SaaS)
MARKETING_MODE=embedded

# ── Web public vars (exposed to browser) ─────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TENANT=roof-technologies
