// ═══════════════════════════════════════════════════════════════════════
// EVENT TRACKING — see SPEC_EVENTS.md
// All Ev* tables group together so they can be audited / extracted as one.
// ═══════════════════════════════════════════════════════════════════════

model EvEvent {
  id                          String            @id @default(cuid())
  publicId                    String            @unique // "EV-1234" for display
  marketId                    String
  market                      Market            @relation(fields: [marketId], references: [id])
  name                        String
  description                 String?           @db.Text
  venueName                   String?
  venueAddress                String?
  venueLat                    Float?
  venueLng                    Float?
  startsAt                    DateTime
  endsAt                      DateTime
  timezone                    String
  status                      EvEventStatus     @default(DRAFT)
  visibility                  EvEventVisibility @default(PRIVATE)
  defaultPlusOnesAllowed      Boolean           @default(false)
  responseWindowOverride      Json?
  confirmationCascadeOverride Json?
  designId                    String?           // MwDesign
  emailSubject                String?
  smsBodyTemplate             String?
  createdBy                   String
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  canceledAt                  DateTime?
  canceledReason              String?
  /// Public read-only share token (SPEC_EVENTS §13 / EV-11). Nullable —
  /// we lazy-generate on first Share click so old events don't get
  /// spurious tokens.
  shareToken                  String?           @unique
  /// Recurring-event linkage. Standalone events have null on both;
  /// a series puts the same seriesId on every occurrence (the canonical
  /// "parent" event being the first one created). recurrenceRule is
  /// stored on the parent only; child occurrences read it through the
  /// parent if they need to display the cadence.
  seriesId                    String?
  series                      EvEvent?          @relation("EvEventSeries", fields: [seriesId], references: [id], onDelete: SetNull)
  occurrences                 EvEvent[]         @relation("EvEventSeries")
  recurrenceRule              String?           // simplified RRULE: FREQ=WEEKLY|BIWEEKLY|MONTHLY;BYDAY=FR;UNTIL=...
  ticketTypes                 EvTicketType[]
  invites                     EvInvite[]
  hosts                       EvHost[]
  subEvents                   EvSubEvent[]
  reminders                   EvReminder[]
  activityLog                 EvActivityLogEntry[]
  batchOffers                 EvBatchOffer[]
  networkingGroupId           String?
  networkingGroup             NetworkingGroup?  @relation(fields: [networkingGroupId], references: [id])

  @@index([marketId, status])
  @@index([startsAt])
  @@index([createdBy])
  @@index([seriesId, startsAt])
  @@index([networkingGroupId])
}

enum EvEventStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELED
}

enum EvEventVisibility {
  PRIVATE
  MARKET_WIDE
  PUBLIC
  /// HOST_ONLY = only the event creator + assigned hosts can see/manage it.
  /// Admins + managers can still see it (they see everything in their market)
  /// but reps in the same market who AREN'T hosts get no visibility at all.
  /// Useful when Janessa wants to run her event without John seeing it.
  HOST_ONLY
}

model EvTicketType {
  id                 String               @id @default(cuid())
  eventId            String
  event              EvEvent              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name               String
