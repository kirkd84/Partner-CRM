// PartnerRadar — Prisma schema
// Source of truth: SPEC.md §4. Do NOT rename fields without updating SPEC.md.
// Additions to indexes/fields for query performance are allowed and should
// be commented inline.

generator client {
  provider      = "prisma-client-js"
  // Railway runs node:22-alpine (musl + OpenSSL 3.x). Emit both the host
  // binary (for local dev on macOS/Linux) and the Alpine/musl binary.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core ────────────────────────────────────────────────────────────

model Market {
  id              String        @id @default(cuid())
  /// Multi-tenant scope. Every market belongs to exactly one tenant.
  /// Backfilled to the "demo" tenant for pre-multi-tenant data; new
  /// markets MUST set this explicitly.
  tenantId        String?
  tenant          Tenant?       @relation(fields: [tenantId], references: [id])
  name            String
  timezone        String        @default("America/Denver")
  defaultCenter   Json // { lat: number, lng: number }
  scrapeRadius    Int           @default(25) // miles
  physicalAddress String? // for CAN-SPAM email footer
  createdAt       DateTime      @default(now())
  users           UserMarket[]
  partners        Partner[]
  hitLists        HitList[]
  hitListPlans    HitListPlan[]    @relation("HitListPlansByMarket")
  scrapeJobs      ScrapeJob[]
  budgetRules     BudgetRule[]
  scrapedLeads    ScrapedLead[]
  evEvents        EvEvent[]
  evWaitlistRule  EvWaitlistRule?
  mwWorkspace     MwWorkspace?
  networkingGroups NetworkingGroup[]
  newsletters     Newsletter[]
  newsletterDrips NewsletterDrip[]
  touchpoints     Touchpoint[]

  @@index([tenantId])
}

model User {
  id                     String               @id @default(cuid())
  /// Multi-tenant scope. Null for SUPER_ADMIN (cross-tenant operator).
  /// Every regular user belongs to exactly one tenant. Backfilled to
  /// the "demo" tenant for pre-multi-tenant data.
  tenantId               String?
  tenant                 Tenant?              @relation(fields: [tenantId], references: [id])
  email                  String               @unique
  passwordHash           String?
  stormCloudUserId       String?              @unique // SSO future
  name                   String
  role                   Role                 @default(REP)
  avatarColor            String
  homeAddress            String?
  officeAddress          String?
  defaultStart           RouteStartMode       @default(OFFICE)
  preferredMapApp        MapApp               @default(GOOGLE)
  aiToneTrainingStatus   ToneTrainingStatus   @default(NOT_STARTED)
  aiToneProfile          Json?
  aiAutonomousApprovals  Int                  @default(0)
  aiAutonomousMode       Boolean              @default(false)
  aiAutonomousEnabledAt  DateTime?
  monthlyRevenueCached   Decimal?             @db.Money
  monthlyRevenueCachedAt DateTime?
  soundEffects           Boolean              @default(true)
  notificationPrefs      Json                 @default("{}")
  active                 Boolean              @default(true)
  tokenVersion           Int                  @default(0) // bump to invalidate JWTs
  lastLoginAt            DateTime?
  createdAt              DateTime             @default(now())
  markets                UserMarket[]
  assignedPartners       Partner[]            @relation("AssignedRep")
  activities             Activity[]
  tasks                  Task[]
  appointments           Appointment[]
  events                 Event[]
  expenses               Expense[]
  appointmentTypeAlerts  AppointmentType[]    @relation("AppointmentTypeAlertUser")
  hitLists               HitList[]
  hitListPlans           HitListPlan[]        @relation("HitListPlansByUser")
  notifications          Notification[]
  calendarConnections    CalendarConnection[]
  toneSamples            AIToneSample[]
  // Event Tracking
  evHostedEvents         EvHost[]             @relation("EvHosts")
  // Marketing Wizard
  mwWorkspaces           MwWorkspaceMember[]
  // Networking groups
  networkingGroupMeetings NetworkingGroupMeeting[] @relation("NetworkingGroupMeetingsByUser")
  // Newsletters they authored
  newsletters             Newsletter[]            @relation("NewslettersByCreator")

  @@index([email])
}

enum Role {
  REP
  MANAGER
  ADMIN
  // SUPER_ADMIN sits above tenants. Belongs to no tenant; can act-as
  // any tenant via /super-admin. Reserved for the platform operator
  // (Copayee). Don't grant to tenant employees.
  SUPER_ADMIN
}

/// Top-level multi-tenant boundary. Every Market, MwWorkspace, and
/// (transitively) every Partner / Activity / Event belongs to one
/// Tenant. SUPER_ADMIN users belong to no tenant and can act-as any.
model Tenant {
  id           String        @id @default(cuid())
  slug         String        @unique // url-safe id; e.g. "roof-technologies"
  name         String
  legalName    String?
  address      String?
  phone        String?
  fromAddress  String?
  websiteUrl   String?
  primaryHex   String?
  secondaryHex String?
  logoUrl      String?
  status       TenantStatus  @default(ACTIVE)
  trialEndsAt  DateTime?
  /// Years to celebrate as partnership-anniversary milestones. Drives
  /// the touchpoint scanner — empty = no milestones, default applied
  /// at read time when the array is null.
  milestoneYears Int[]       @default([])
  /// Per-tenant default congrats messages. Stored as
  /// { BIRTHDAY: { subject, body }, BUSINESS_ANNIVERSARY: {...},
  ///   PARTNERSHIP_MILESTONE: {...} }. Render still substitutes
  /// `{{contactName}}`, `{{companyName}}`, `{{years}}`, `{{sender}}`,
  /// `{{tenantName}}` so the manager can write once + reuse.
  /// Null = use the hardcoded defaults in lib/touchpoints/send.ts.
  touchpointTemplates Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  markets      Market[]
  users        User[]
  workspaces   MwWorkspace[]
  stageConfigs StageConfig[]
  networkingGroups NetworkingGroup[]
  newsletters Newsletter[]

  @@index([status])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum RouteStartMode {
  HOME
  OFFICE
  LAST_STOP
  CUSTOM
}

enum MapApp {
  GOOGLE
  APPLE
}

enum ToneTrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  CALIBRATED
  REP_APPROVED
}

model UserMarket {
  userId    String
  marketId  String
  isPrimary Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@id([userId, marketId])
  @@index([marketId])
}

// ─── Partners ────────────────────────────────────────────────────────

model Partner {
  id                  String               @id @default(cuid())
  publicId            String               @unique // "PR-1234" for display
  marketId            String
  market              Market               @relation(fields: [marketId], references: [id])
  companyName         String
  partnerType         PartnerType
  customType          String? // when partnerType = OTHER
  address             String?
  addressLine2        String?
  city                String?
  state               String?
  zip                 String?
  lat                 Float?
  lng                 Float?
  website             String?
  notes               String?              @db.Text
  stage               PartnerStage         @default(NEW_LEAD)
  stageChangedAt      DateTime             @default(now())
  source              LeadSource           @default(MANUAL)
  sourceDetails       Json?
  assignedRepId       String?
  assignedRep         User?                @relation("AssignedRep", fields: [assignedRepId], references: [id])
  smsConsent          Boolean              @default(false)
  smsConsentAt        DateTime?
  smsConsentBy        String?
  smsConsentMethod    SmsConsentMethod?
  emailUnsubscribedAt DateTime?
  // Customer-vs-partner: partners can also be customers (we roofed
  // their house, or they refer AND we work for them). customerOnly
  // means they leave the partner pipeline entirely.
  isCustomer          Boolean              @default(false)
  customerOnly        Boolean              @default(false)
  becameCustomerAt    DateTime?
  // Reason a partner went INACTIVE — required by the UI when
  // transitioning to INACTIVE so reports can show why deals die.
  dormantReason       String?              @db.Text
  // Referral graph — who told us about this partner (if anyone).
  referredByPartnerId String?
  referredByPartner   Partner?             @relation("PartnerReferral", fields: [referredByPartnerId], references: [id])
  referredPartners    Partner[]            @relation("PartnerReferral")
  // Original business-card photo (R2 key) kept for audit if the lead
  // came from /scan; null for everything else.
  businessCardImageUrl String?
  /// Date the partner's business was founded / opened. Renders as
  /// month + day on the touchpoints view (year omitted in display)
  /// so reps can wish them happy anniversary every year.
  businessAnniversaryOn DateTime?
  /// Date this company became a working partner — drives the
  /// "1-year partnership" / "2-year partnership" milestones on the
  /// touchpoints view. Set automatically when the stage transitions
  /// to ACTIVATED for the first time. Distinct from activatedAt
  /// which can move forward + back if a partner re-activates after
  /// going dormant — partneredOn is the first-ever partnership date.
  partneredOn         DateTime?
  stormCloudId        String?              @unique
  activatedAt         DateTime?
  activatedBy         String?
  archivedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  contacts            Contact[]
  activities          Activity[]
  tasks               Task[]
  appointments        Appointment[]
  events              Event[]
  expenses            Expense[]
  files               File[]
  revenueAttributions RevenueAttribution[]
  hitListStops        HitListStop[]
  tags                PartnerTag[]
  // Event Tracking — fallback waitlist
  autoWaitlistEligible Boolean             @default(false)
  waitlistPriority     Int?
  evInvites            EvInvite[]
  networkingGroupMemberships NetworkingGroupMembership[]
  touchpoints          Touchpoint[]
  dripEnrollments      NewsletterDripEnrollment[]
  // Reliability stats updated by the post-event attendance postmortem.
  // All three are moving averages over the last N events; null until
  // the partner has attended (or no-showed) anything.
  eventAcceptanceRate  Float?              // % of invites accepted/confirmed
  eventShowRate        Float?              // % of confirmed that attended
  reliabilityScore     Float?              // composite 0..100 for sorting the auto-waitlist

  @@index([marketId, stage])
  @@index([assignedRepId])
  @@index([archivedAt])
  @@index([stormCloudId])
  @@index([stageChangedAt])
}

enum PartnerType {
  REALTOR
  PROPERTY_MANAGER
  INSURANCE_AGENT
  MORTGAGE_BROKER
  HOME_INSPECTOR
  PUBLIC_ADJUSTER
  REAL_ESTATE_ATTORNEY
  HVAC
  PLUMBING
  ELECTRICAL
  LANDSCAPER
  GENERAL_CONTRACTOR
  RESTORATION_MITIGATION
  FACILITIES_MANAGER_COMMERCIAL
  OTHER
}

enum PartnerStage {
  NEW_LEAD
  RESEARCHED
  INITIAL_CONTACT
  MEETING_SCHEDULED
  IN_CONVERSATION
  PROPOSAL_SENT
  ACTIVATED
  INACTIVE
}

/// Per-tenant overrides for how each PartnerStage renders. The enum
/// stays the source of truth for type safety + existing code; this
/// table lets a manager rename the label, recolor, or reorder without
/// a code deploy. Adding net-new stages is intentionally NOT supported
/// here yet (would require a code change for cadence triggers,
/// automation rules, reports). v1 = rename + recolor + reorder only.
///
/// Seeded by instrumentation.ts on boot from the enum + STAGE_LABELS
/// defaults, idempotent. Per-tenant rows are created lazily.
model StageConfig {
  id        String       @id @default(cuid())
  tenantId  String?      // null = global default; tenant rows override
  tenant    Tenant?      @relation(fields: [tenantId], references: [id])
  stage     PartnerStage
  label     String
  color     String       // hex like #3b82f6 — matches existing STAGE_COLORS palette
  sortOrder Int          @default(0)
  archived  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, stage])
  @@index([tenantId, sortOrder])
}

enum LeadSource {
  MANUAL
  SCRAPED
  REFERRAL
  IMPORT
  BUSINESS_CARD
}

/// Networking groups Roof Tech belongs to or wants to track — CAI,
/// BNI, Chamber, REIA, etc. We log meetings of the group, partner
/// memberships, and the rep's spend (dues, sponsorships, dinners) so
/// a manager can see whether the group is paying off.
model NetworkingGroup {
  id            String       @id @default(cuid())
  tenantId      String?
  tenant        Tenant?      @relation(fields: [tenantId], references: [id])
  marketId      String?
  market        Market?      @relation(fields: [marketId], references: [id])
  name          String
  /// Short code used by the rep — "BNI", "CAI", "Chamber" — for badges
  /// and the table view. Optional; we surface name when missing.
  shortCode     String?
  websiteUrl    String?
  meetingCadence String?     // free text — "1st + 3rd Tuesday", "Weekly Friday 7am"
  notes         String?      @db.Text
  archivedAt    DateTime?
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   NetworkingGroupMembership[]
  meetings      NetworkingGroupMeeting[]
  events        EvEvent[]
  expenses      Expense[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([marketId])
  @@index([archivedAt])
}

/// Many-to-many between Partner and NetworkingGroup. We track who's a
/// member so the group page can show 'best partners in this group'
/// ranked by activity volume + revenue attribution.
model NetworkingGroupMembership {
  id        String          @id @default(cuid())
  groupId   String
  group     NetworkingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  partnerId String
  partner   Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  /// Optional role at the group — Member / Officer / Sponsor / Guest.
  role      String?
  joinedAt  DateTime?
  leftAt    DateTime?
  notes     String?
  createdAt DateTime        @default(now())

  @@unique([groupId, partnerId])
  @@index([groupId])
  @@index([partnerId])
}

/// Newsletter blasts — one row per drafted/sent campaign. Body is
/// stored as plain text for the v1 cut; rich-text comes later. The
/// audienceFilter JSON describes the segment the manager picked
/// (partner types, stages, groups, exclude-customers flag) so we can
/// reproduce the send list when reading back the history.
///
/// CAN-SPAM compliance is enforced at send time, not stored:
///   - physical-address footer is appended from Tenant.address
///   - unsubscribe link is appended via lib/messaging/unsubscribe-token
///   - Partner.emailUnsubscribedAt gates per-recipient
model Newsletter {
  id              String           @id @default(cuid())
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  /// Optional market scope. Null = every market in the tenant.
  marketId        String?
  market          Market?          @relation(fields: [marketId], references: [id])
  subject         String
  /// Plain-text body — used for the text/plain MIME alternative AND as
  /// the markdown source the rich-text toolbar edits. Stored as
  /// markdown when bodyMarkdown is true; otherwise treated as raw plain text.
  bodyText        String           @db.Text
  /// Whether bodyText is markdown (rendered to HTML at send time) or
  /// plain-text-only. New newsletters default true; legacy v1 ones
  /// stayed false and render unchanged.
  bodyMarkdown    Boolean          @default(false)
  /// Audience filter — picked at compose time.
  audienceFilter  Json
  status          NewsletterStatus @default(DRAFT)
  recipientCount  Int              @default(0)
  sentCount       Int              @default(0)
  blockedCount    Int              @default(0)
  errorCount      Int              @default(0)
  errorSamples    Json?
  /// Scheduled future-send. Null = send immediately when the manager
  /// clicks Send. The /api/cron/newsletter-tick endpoint scans for
  /// rows with status=SCHEDULED and scheduledAt <= now and fires.
  scheduledAt     DateTime?
  /// Aggregate engagement counters. Per-recipient state lives on
  /// NewsletterRecipient; these are the rolled-up totals shown on
  /// the detail page.
  openCount       Int              @default(0)
  clickCount      Int              @default(0)
  createdBy       String
  creator         User             @relation("NewslettersByCreator", fields: [createdBy], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sentAt          DateTime?
  recipients      NewsletterRecipient[]

  @@index([tenantId, status])
  @@index([marketId])
  @@index([createdBy])
  @@index([status, scheduledAt])
}

/// Per-recipient state for a newsletter send. Created when the rep
/// clicks Send + we look up the audience; lifecycle is driven by
/// the Resend webhook (delivered / opened / clicked / bounced).
model NewsletterRecipient {
  id             String     @id @default(cuid())
  newsletterId   String
  newsletter     Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  partnerId      String
  contactId      String?
  email          String
  /// Resend message id — populated after send succeeds. We look up by
  /// this in the webhook receiver to find the row to update.
  resendId       String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  firstClickedAt DateTime?
  bouncedAt      DateTime?
  bounceReason   String?
  errorMessage   String?
  createdAt      DateTime   @default(now())

  @@index([newsletterId])
  @@index([resendId])
  @@index([partnerId])
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// ─── Touchpoints (birthday / anniversary / partnership) ──────────────

/// A scheduled "you should reach out to this partner today" item.
/// Created automatically by the touchpoints scanner when a contact's
/// birthday, a partner's business anniversary, or a partnership
/// milestone (1yr, 2yr) falls within the upcoming window.
///
/// channel + scheduledFor describe the auto-congrats outreach (SMS or
/// email). Once the message goes out the row is marked SENT and won't
/// be re-scheduled until next year. uniqueKey de-dupes — see
/// touchpoints.scan() for the format.
model Touchpoint {
  id            String              @id @default(cuid())
  tenantId      String?
  marketId      String?
  market        Market?             @relation(fields: [marketId], references: [id])
  partnerId     String
  partner       Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  /// For BIRTHDAY only — which contact's birthday this is.
  contactId     String?
  kind          TouchpointKind
  /// The actual occurrence date THIS YEAR — used for sorting "upcoming".
  occurrenceOn  DateTime
  /// When the auto-congrats should fire. Pre-set to morning-of in the
  /// market's timezone, but the rep can adjust on the touchpoints page.
  scheduledFor  DateTime
  channel       TouchpointChannel
  status        TouchpointStatus    @default(SCHEDULED)
  message       String?             @db.Text
  /// Free-form metadata — for partnership milestones the year (1,2,5);
  /// for birthdays the contact's name; etc.
  meta          Json?
  sentAt        DateTime?
  errorMessage  String?
  /// Manager who scheduled / canceled / overrode the message.
  createdBy     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  /// De-dupe key — kind:partnerId:occurrenceYear (or :contactId for
  /// birthdays). Prevents the scanner from scheduling the same milestone
  /// twice on consecutive cron runs.
  uniqueKey     String              @unique

  @@index([tenantId, scheduledFor, status])
  @@index([marketId, scheduledFor, status])
  @@index([partnerId])
}

enum TouchpointKind {
  BIRTHDAY
  BUSINESS_ANNIVERSARY
  PARTNERSHIP_MILESTONE
}

enum TouchpointChannel {
  SMS
  EMAIL
  /// Manual reminder only — no automated send. Renders on the
  /// touchpoints page so the rep can call/text on their own.
  MANUAL
}

enum TouchpointStatus {
  SCHEDULED
  SENT
  SKIPPED
  FAILED
  CANCELED
}

// ─── Newsletter drips (multi-step recurring sequences) ───────────────

/// An ordered series of newsletter steps that fires at delayDays
/// intervals after enrollment. Triggered automatically when a partner
/// matches the audienceFilter (e.g. "newly activated") or manually.
///
/// Send pipeline: a cron tick reads NewsletterDripEnrollment rows
/// where nextSendAt <= now() AND status=ACTIVE, instantiates a
/// Newsletter row from the step template, and advances the enrollment
/// to the next step. Reuses the existing newsletter send infrastructure
/// (recipient rows, Resend webhook tracking, unsubscribe headers).
model NewsletterDrip {
  id              String                       @id @default(cuid())
  tenantId        String?
  marketId        String?
  market          Market?                      @relation(fields: [marketId], references: [id])
  name            String
  /// Short manager-facing description of who this drip targets.
  description     String?
  audienceFilter  Json
  triggerType     DripTriggerType              @default(MANUAL)
  triggerConfig   Json?
  active          Boolean                      @default(true)
  steps           NewsletterDripStep[]
  enrollments     NewsletterDripEnrollment[]
  createdBy       String
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@index([tenantId, active])
  @@index([marketId, active])
}

model NewsletterDripStep {
  id            String          @id @default(cuid())
  dripId        String
  drip          NewsletterDrip  @relation(fields: [dripId], references: [id], onDelete: Cascade)
  /// 0-indexed position in the sequence.
  position      Int
  /// Days from previous step (or from enrollment for position=0).
  delayDays     Int             @default(0)
  subject       String
  bodyText      String          @db.Text
  bodyMarkdown  Boolean         @default(true)

  @@unique([dripId, position])
}

model NewsletterDripEnrollment {
  id              String                @id @default(cuid())
  dripId          String
  drip            NewsletterDrip        @relation(fields: [dripId], references: [id], onDelete: Cascade)
  partnerId       String
  partner         Partner               @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  contactId       String?
  email           String
  /// Position of the NEXT step to send. Equal to drip.steps.length
  /// when the partner has finished the sequence.
  position        Int                   @default(0)
  nextSendAt      DateTime?
  status          DripEnrollmentStatus  @default(ACTIVE)
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  unsubscribedAt  DateTime?

  @@unique([dripId, partnerId, contactId])
  @@index([nextSendAt, status])
  @@index([partnerId])
}

enum DripTriggerType {
  /// Auto-enroll partners on stage transition to ACTIVATED.
  ON_PARTNER_ACTIVATED
  /// Auto-enroll when a specific tag is added to the partner.
  ON_TAG_ADDED
  /// Manager hand-picks who to enroll from /newsletters/drips/[id].
  MANUAL
}

enum DripEnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  UNSUBSCRIBED
}

/// Each time a rep attends a meeting of the group. Lighter-weight than
/// an EvEvent because most BNI/CAI meetings aren't ours to host — we
/// just want to log who went, what was spent, and any partners we
/// encountered.
model NetworkingGroupMeeting {
  id        String          @id @default(cuid())
  groupId   String
  group     NetworkingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// Rep who attended; for joint-attendance log multiple rows.
  userId    String
  user      User            @relation("NetworkingGroupMeetingsByUser", fields: [userId], references: [id])
  occurredOn DateTime
  topic     String?
  notes     String?         @db.Text
  /// Comma- or newline-separated quick list of partners present. The
  /// authoritative "this partner came" link goes via Activity rows
  /// the rep creates for each touchpoint; this field is just the
  /// scratch pad they fill in during the meeting.
  attendeesNote String?
  spendCents Int?           // optional dues/dinner spend for this meeting
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([groupId, occurredOn])
  @@index([userId])
}

enum SmsConsentMethod {
  VERBAL
  WRITTEN
  EMAIL
  IN_PERSON
}

model PartnerTag {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tag       String

  @@unique([partnerId, tag])
  @@index([partnerId, tag])
}

model Contact {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name         String
  title        String?
  phones       Json // [{ number, label, primary }]
  emails       Json // [{ address, label, primary, unsubscribedAt }]
  isPrimary    Boolean  @default(false)
  smsConsent   Boolean  @default(false)
  emailConsent Boolean  @default(true)
  /// Birthday — month + day only, no year, for privacy. Either both
  /// set or both null. Drives the upcoming-birthdays touchpoints view.
  birthMonth   Int?
  birthDay     Int?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([partnerId])
  @@index([birthMonth, birthDay])
}

// ─── Activities / Tasks / Appointments / Expenses ────────────────────

model Activity {
  id        String       @id @default(cuid())
  partnerId String
  partner   Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  type      ActivityType
  body      String?      @db.Text
  metadata  Json?
  createdAt DateTime     @default(now())

  @@index([partnerId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

enum ActivityType {
  COMMENT
  CALL
  SMS_OUT
  SMS_IN
  EMAIL_OUT
  EMAIL_IN
  VISIT
  MEETING_HELD
  STAGE_CHANGE
  AI_DRAFT_REQUESTED
