// ─── Hit List ────────────────────────────────────────────────────────

/// A multi-day route plan. The v2 planner takes "X partners closest to
/// this address, fitting in working-hours" and breaks it across as
/// many days as it needs. Each day is a HitList row; HitListPlan is
/// the parent that records how the breakout was generated so we can
/// show "this is day 2 of 4" and re-plan the whole thing if the rep
/// changes the input.
model HitListPlan {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("HitListPlansByUser", fields: [userId], references: [id])
  marketId      String
  market        Market    @relation("HitListPlansByMarket", fields: [marketId], references: [id])
  /// Optional human label — "Westside loop" / "Q3 reactivation".
  label         String?
  /// Address the rep is leaving from on day 1; subsequent days reset
  /// to this address (assume rep returns home each night).
  startAddress  String
  startLat      Float
  startLng      Float
  /// Where the rep ends on the final day. END_AT_HOME means same as
  /// startAddress; LAST_STOP means stop optimization wherever the
  /// last partner is.
  endMode       RouteEndMode @default(END_AT_HOME)
  endAddress    String?
  endLat        Float?
  endLng        Float?
  /// Plan-wide config copied to each day's HitList row.
  minutesPerStop  Int    @default(15)
  /// Working-hours window in local minutes from midnight. Default
  /// 9am→5pm = 540→1020.
  startTimeMin   Int     @default(540)
  endTimeMin     Int     @default(1020)
  /// Optional lunch break — null means no lunch carve-out.
  lunchStartMin  Int?
  lunchDurationMin Int?
  /// Aggregate over all days in the plan.
  totalStops     Int     @default(0)
  totalDays      Int     @default(0)
  totalMinutes   Int     @default(0)
  totalDistance  Float   @default(0)
  /// Source of the partner pool — "closest:lat,lng:radiusMi:N",
  /// "manual", "lasso:listId". Stored for audit + re-plan.
  sourceKind     String  @default("manual")
  sourceMeta     Json?
  generatedAt    DateTime @default(now())
  hitLists       HitList[]

  @@index([userId, generatedAt])
  @@index([marketId, generatedAt])
}

enum RouteEndMode {
  END_AT_HOME    // return to start address
  LAST_STOP      // end wherever the last partner is
}

model HitList {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  marketId      String
  market        Market         @relation(fields: [marketId], references: [id])
  date          DateTime // local midnight
  startAddress  String
  startLat      Float
  startLng      Float
  startMode     RouteStartMode
  totalDistance Float? // miles
  totalDuration Int? // minutes
  generatedAt   DateTime       @default(now())
  /// v2 multi-day planner — null for legacy single-day lists, set when
  /// the list belongs to a multi-day plan.
  planId        String?
  plan          HitListPlan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  /// Position in the plan (0-indexed). Null for ad-hoc lists.
  dayIndex      Int?
  /// Per-day config copied from HitListPlan at generation time so we
  /// can re-render the day's schedule without round-tripping through
  /// the parent.
  minutesPerStop Int   @default(15)
  startTimeMin   Int   @default(540)
  endTimeMin     Int   @default(1020)
  lunchStartMin  Int?
  lunchDurationMin Int?
  /// Where this day ends. For day N where N < totalDays-1 the rep
  /// always returns to startAddress (so they can sleep at home).
  /// Only the final day uses HitListPlan.endMode.
  endsAtStart    Boolean @default(true)
  stops         HitListStop[]

  @@unique([userId, date])
}

model HitListStop {
  id                 String    @id @default(cuid())
  hitListId          String
  hitList            HitList   @relation(fields: [hitListId], references: [id], onDelete: Cascade)
  partnerId          String
  partner            Partner   @relation(fields: [partnerId], references: [id])
  order              Int
  plannedArrival     DateTime
  plannedDurationMin Int       @default(20)
  isAppointmentLock  Boolean   @default(false)
  /// v2 route planner: distance + drive time from the previous stop
  /// (or from the day's startAddress for the first stop). Lets the
  /// detail view show leg-by-leg + total drive time without
  /// recomputing on every render.
  distanceFromPrevMi   Float?
  durationFromPrevMin  Int?
  /// Estimated arrival ETA — populated by the planner so the rep
  /// can quickly see "I should be at stop 5 by 1:45pm". Updated when
  /// the rep marks earlier stops complete with a real timestamp.
  arrivalEta           DateTime?
  completedAt        DateTime?
  skippedAt          DateTime?
  skipReason         String?
  notes              String?

  @@index([hitListId, order])
}

