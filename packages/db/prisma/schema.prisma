// PartnerRadar — Prisma schema
// Source of truth: SPEC.md §4. Do NOT rename fields without updating SPEC.md.
// Additions to indexes/fields for query performance are allowed and should
// be commented inline.

generator client {
  provider      = "prisma-client-js"
  // Railway runs node:22-alpine (musl + OpenSSL 3.x). Emit both the host
  // binary (for local dev on macOS/Linux) and the Alpine/musl binary.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core ────────────────────────────────────────────────────────────

model Market {
  id              String        @id @default(cuid())
  /// Multi-tenant scope. Every market belongs to exactly one tenant.
  /// Backfilled to the "demo" tenant for pre-multi-tenant data; new
  /// markets MUST set this explicitly.
  tenantId        String?
  tenant          Tenant?       @relation(fields: [tenantId], references: [id])
  name            String
  timezone        String        @default("America/Denver")
  defaultCenter   Json // { lat: number, lng: number }
  scrapeRadius    Int           @default(25) // miles
  physicalAddress String? // for CAN-SPAM email footer
  createdAt       DateTime      @default(now())
  users           UserMarket[]
  partners        Partner[]
  hitLists        HitList[]
  scrapeJobs      ScrapeJob[]
  budgetRules     BudgetRule[]
  scrapedLeads    ScrapedLead[]
  evEvents        EvEvent[]
  evWaitlistRule  EvWaitlistRule?
  mwWorkspace     MwWorkspace?

  @@index([tenantId])
}

model User {
  id                     String               @id @default(cuid())
  /// Multi-tenant scope. Null for SUPER_ADMIN (cross-tenant operator).
  /// Every regular user belongs to exactly one tenant. Backfilled to
  /// the "demo" tenant for pre-multi-tenant data.
  tenantId               String?
  tenant                 Tenant?              @relation(fields: [tenantId], references: [id])
  email                  String               @unique
  passwordHash           String?
  stormCloudUserId       String?              @unique // SSO future
  name                   String
  role                   Role                 @default(REP)
  avatarColor            String
  homeAddress            String?
  officeAddress          String?
  defaultStart           RouteStartMode       @default(OFFICE)
  preferredMapApp        MapApp               @default(GOOGLE)
  aiToneTrainingStatus   ToneTrainingStatus   @default(NOT_STARTED)
  aiToneProfile          Json?
  aiAutonomousApprovals  Int                  @default(0)
  aiAutonomousMode       Boolean              @default(false)
  aiAutonomousEnabledAt  DateTime?
  monthlyRevenueCached   Decimal?             @db.Money
  monthlyRevenueCachedAt DateTime?
  soundEffects           Boolean              @default(true)
  notificationPrefs      Json                 @default("{}")
  active                 Boolean              @default(true)
  tokenVersion           Int                  @default(0) // bump to invalidate JWTs
  lastLoginAt            DateTime?
  createdAt              DateTime             @default(now())
  markets                UserMarket[]
  assignedPartners       Partner[]            @relation("AssignedRep")
  activities             Activity[]
  tasks                  Task[]
  appointments           Appointment[]
  events                 Event[]
  expenses               Expense[]
  appointmentTypeAlerts  AppointmentType[]    @relation("AppointmentTypeAlertUser")
  hitLists               HitList[]
  notifications          Notification[]
  calendarConnections    CalendarConnection[]
  toneSamples            AIToneSample[]
  // Event Tracking
  evHostedEvents         EvHost[]             @relation("EvHosts")
  // Marketing Wizard
  mwWorkspaces           MwWorkspaceMember[]

  @@index([email])
}

enum Role {
  REP
  MANAGER
  ADMIN
  // SUPER_ADMIN sits above tenants. Belongs to no tenant; can act-as
  // any tenant via /super-admin. Reserved for the platform operator
  // (Copayee). Don't grant to tenant employees.
  SUPER_ADMIN
}

/// Top-level multi-tenant boundary. Every Market, MwWorkspace, and
/// (transitively) every Partner / Activity / Event belongs to one
/// Tenant. SUPER_ADMIN users belong to no tenant and can act-as any.
model Tenant {
  id           String        @id @default(cuid())
  slug         String        @unique // url-safe id; e.g. "roof-technologies"
  name         String
  legalName    String?
  address      String?
  phone        String?
  fromAddress  String?
  websiteUrl   String?
  primaryHex   String?
  secondaryHex String?
  logoUrl      String?
  status       TenantStatus  @default(ACTIVE)
  trialEndsAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  markets      Market[]
  users        User[]
  workspaces   MwWorkspace[]

  @@index([status])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum RouteStartMode {
  HOME
  OFFICE
  LAST_STOP
  CUSTOM
}

enum MapApp {
  GOOGLE
  APPLE
}

enum ToneTrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  CALIBRATED
  REP_APPROVED
}

model UserMarket {
  userId    String
  marketId  String
  isPrimary Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@id([userId, marketId])
  @@index([marketId])
}

// ─── Partners ────────────────────────────────────────────────────────

model Partner {
  id                  String               @id @default(cuid())
  publicId            String               @unique // "PR-1234" for display
  marketId            String
  market              Market               @relation(fields: [marketId], references: [id])
  companyName         String
  partnerType         PartnerType
  customType          String? // when partnerType = OTHER
  address             String?
  addressLine2        String?
  city                String?
  state               String?
  zip                 String?
  lat                 Float?
  lng                 Float?
  website             String?
  notes               String?              @db.Text
  stage               PartnerStage         @default(NEW_LEAD)
  stageChangedAt      DateTime             @default(now())
  source              LeadSource           @default(MANUAL)
  sourceDetails       Json?
  assignedRepId       String?
  assignedRep         User?                @relation("AssignedRep", fields: [assignedRepId], references: [id])
  smsConsent          Boolean              @default(false)
  smsConsentAt        DateTime?
  smsConsentBy        String?
  smsConsentMethod    SmsConsentMethod?
  emailUnsubscribedAt DateTime?
  stormCloudId        String?              @unique
  activatedAt         DateTime?
  activatedBy         String?
  archivedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  contacts            Contact[]
  activities          Activity[]
  tasks               Task[]
  appointments        Appointment[]
  events              Event[]
  expenses            Expense[]
  files               File[]
  revenueAttributions RevenueAttribution[]
  hitListStops        HitListStop[]
  tags                PartnerTag[]
  // Event Tracking — fallback waitlist
  autoWaitlistEligible Boolean             @default(false)
  waitlistPriority     Int?
  evInvites            EvInvite[]
  // Reliability stats updated by the post-event attendance postmortem.
  // All three are moving averages over the last N events; null until
  // the partner has attended (or no-showed) anything.
  eventAcceptanceRate  Float?              // % of invites accepted/confirmed
  eventShowRate        Float?              // % of confirmed that attended
  reliabilityScore     Float?              // composite 0..100 for sorting the auto-waitlist

  @@index([marketId, stage])
  @@index([assignedRepId])
  @@index([archivedAt])
  @@index([stormCloudId])
  @@index([stageChangedAt])
}

enum PartnerType {
  REALTOR
  PROPERTY_MANAGER
  INSURANCE_AGENT
  MORTGAGE_BROKER
  HOME_INSPECTOR
  PUBLIC_ADJUSTER
  REAL_ESTATE_ATTORNEY
  HVAC
  PLUMBING
  ELECTRICAL
  LANDSCAPER
  GENERAL_CONTRACTOR
  RESTORATION_MITIGATION
  FACILITIES_MANAGER_COMMERCIAL
  OTHER
}

enum PartnerStage {
  NEW_LEAD
  RESEARCHED
  INITIAL_CONTACT
  MEETING_SCHEDULED
  IN_CONVERSATION
  PROPOSAL_SENT
  ACTIVATED
  INACTIVE
}

enum LeadSource {
  MANUAL
  SCRAPED
  REFERRAL
  IMPORT
}

enum SmsConsentMethod {
  VERBAL
  WRITTEN
  EMAIL
  IN_PERSON
}

model PartnerTag {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tag       String

  @@unique([partnerId, tag])
  @@index([partnerId, tag])
}

model Contact {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name         String
  title        String?
  phones       Json // [{ number, label, primary }]
  emails       Json // [{ address, label, primary, unsubscribedAt }]
  isPrimary    Boolean  @default(false)
  smsConsent   Boolean  @default(false)
  emailConsent Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())

  @@index([partnerId])
}

// ─── Activities / Tasks / Appointments / Expenses ────────────────────

model Activity {
  id        String       @id @default(cuid())
  partnerId String
  partner   Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  type      ActivityType
  body      String?      @db.Text
  metadata  Json?
  createdAt DateTime     @default(now())

  @@index([partnerId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

enum ActivityType {
  COMMENT
  CALL
  SMS_OUT
  SMS_IN
  EMAIL_OUT
  EMAIL_IN
  VISIT
  MEETING_HELD
  STAGE_CHANGE
  AI_DRAFT_REQUESTED
  AI_MESSAGE_SENT_AUTO
  AI_MESSAGE_APPROVED
  ACTIVATION
  ASSIGNMENT
  CLAIM
  EVENT_ATTENDED
  EVENT_NO_SHOW
  EVENT_WALKED_IN
}

model Task {
  id          String       @id @default(cuid())
  partnerId   String?
  partner     Partner?     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  assigneeId  String
  assignee    User         @relation(fields: [assigneeId], references: [id])
  title       String
  description String?      @db.Text
  dueAt       DateTime?
  completedAt DateTime?
  priority    TaskPriority @default(NORMAL)
  createdAt   DateTime     @default(now())

  @@index([assigneeId, completedAt])
  @@index([partnerId])
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Appointment {
  id                 String            @id @default(cuid())
  partnerId          String?
  partner            Partner?          @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  // `type` stays as free-text for legacy + custom-one-off appointments.
  // `appointmentTypeId` is the preferred path now — admin-managed catalog.
  type               String
  appointmentTypeId  String?
  appointmentType    AppointmentType?  @relation(fields: [appointmentTypeId], references: [id])
  title              String
  location           String?
  startsAt           DateTime
  endsAt             DateTime
  allDay             Boolean           @default(false)
  notes              String?           @db.Text
  externalCalendarId String?
  externalProvider   String? // "google" / "apple" / "storm"
  source             AppointmentSource @default(INTERNAL)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId, startsAt])
  @@index([partnerId])
  @@index([appointmentTypeId])
}

enum AppointmentSource {
  INTERNAL
  GOOGLE
  APPLE
  STORM
}

/// Admin-managed catalog of appointment types (Storm-parity).
/// Reps pick from this list when creating an appointment; each type
/// carries defaults for duration, reminder timing, and a fallback
/// alert user if the appointment is left unassigned.
model AppointmentType {
  id                    String        @id @default(cuid())
  name                  String        @unique
  durationMinutes       Int           @default(30)
  /// null = no automatic reminder; otherwise minutes before startsAt.
  reminderMinutesBefore Int?
  /// When true and the appointment has no assignee, notify `alertUser`.
  alertIfUnassigned     Boolean       @default(false)
  alertUserId           String?
  alertUser             User?         @relation("AppointmentTypeAlertUser", fields: [alertUserId], references: [id])
  /// Soft-delete — archived types don't show in the new-appointment picker
  /// but existing Appointments keep their reference.
  archivedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  appointments          Appointment[]

  @@index([archivedAt])
}

// Partner-level networking events — Chamber mixers, broker opens,
// lunch-and-learns, conferences. Distinct from 1:1 Appointments: these
// are the "third places" where we meet partners in groups.
model Event {
  id        String    @id @default(cuid())
  partnerId String
  partner   Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String    // "Chamber" / "Broker open" / "Lunch-and-learn" / "Mixer" / "Conference" / "Other"
  title     String
  location  String?
  startsAt  DateTime
  endsAt    DateTime?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())

  @@index([partnerId, startsAt])
  @@index([userId])
}

model Expense {
  id             String          @id @default(cuid())
  partnerId      String
  partner        Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  amount         Decimal         @db.Money
  description    String
  category       String // "Meal" / "Gift" / "Event" / "Travel" / "Other"
  occurredOn     DateTime
  receiptFileId  String?
  approvalStatus ExpenseApproval @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime        @default(now())

  @@index([partnerId])
  @@index([userId, approvalStatus])
  @@index([approvalStatus])
}

enum ExpenseApproval {
  AUTO_APPROVED
  PENDING
  APPROVED
  REJECTED
}

model BudgetRule {
  id                            String   @id @default(cuid())
  marketId                      String?
  market                        Market?  @relation(fields: [marketId], references: [id])
  repId                         String? // null = default rule
  autoApproveUnder              Decimal  @default(25) @db.Money
  managerApproveUnder           Decimal  @default(100) @db.Money
  monthlyBudgetPercentOfRevenue Decimal? // e.g., 0.05 = 5%
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

// ─── Revenue (synced from Storm) ─────────────────────────────────────

model RevenueAttribution {
  id                  String   @id @default(cuid())
  partnerId           String
  partner             Partner  @relation(fields: [partnerId], references: [id])
  stormCloudProjectId String   @unique
  amount              Decimal  @db.Money
  earnedOn            DateTime
  syncedAt            DateTime @default(now())

  @@index([partnerId])
  @@index([earnedOn])
}

// ─── Hit List ────────────────────────────────────────────────────────

model HitList {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  marketId      String
  market        Market         @relation(fields: [marketId], references: [id])
  date          DateTime // local midnight
  startAddress  String
  startLat      Float
  startLng      Float
  startMode     RouteStartMode
  totalDistance Float? // miles
  totalDuration Int? // minutes
  generatedAt   DateTime       @default(now())
  stops         HitListStop[]

  @@unique([userId, date])
}

model HitListStop {
  id                 String    @id @default(cuid())
  hitListId          String
  hitList            HitList   @relation(fields: [hitListId], references: [id], onDelete: Cascade)
  partnerId          String
  partner            Partner   @relation(fields: [partnerId], references: [id])
  order              Int
  plannedArrival     DateTime
  plannedDurationMin Int       @default(20)
  isAppointmentLock  Boolean   @default(false)
  completedAt        DateTime?
  skippedAt          DateTime?
  skipReason         String?
  notes              String?

  @@index([hitListId, order])
}

// ─── Scraping ────────────────────────────────────────────────────────

model ScrapeJob {
  id        String        @id @default(cuid())
  marketId  String
  market    Market        @relation(fields: [marketId], references: [id])
  source    ScrapeSource
  name      String
  filters   Json // { partnerTypes:[], radiusMi, keywords:[], selectorMap? }
  cadence   String // cron expression
  active    Boolean       @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdBy String
  createdAt DateTime      @default(now())
  leads     ScrapedLead[]

  @@index([marketId, active])
}

enum ScrapeSource {
  GOOGLE_PLACES
  YELP
  LICENSING_BOARD
  CUSTOM_URL
  // Phase 4 expanded scope — free, legal prospect ingestion sources.
  // See STATUS.md §"Prospect ingestion pipeline" for priority + refresh
  // cadence. Zillow / LinkedIn are deliberately excluded (ToS risk).
  NMLS // federal mortgage broker + loan officer registry
  STATE_REALTY // per-state real estate commission (CO DORA, KS KREC, ...)
  STATE_INSURANCE // per-state insurance department producer DBs
  OVERTURE // Overture Maps open places data (MS/Meta/Amazon/TomTom)
  CHAMBER // chamber of commerce member directories
  STORM_CLOUD // historical touchpoints from Storm (parking-lot, gated on Storm dev team)
}

model ScrapedLead {
  id                String            @id @default(cuid())
  scrapeJobId       String
  scrapeJob         ScrapeJob         @relation(fields: [scrapeJobId], references: [id], onDelete: Cascade)
  marketId          String
  market            Market            @relation(fields: [marketId], references: [id])
  rawPayload        Json
  normalized        Json // { companyName, partnerType, address, contacts[], ... }
  dedupHash         String
  status            ScrapedLeadStatus @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  approvedPartnerId String?           @unique
  rejectedReason    String?
  createdAt         DateTime          @default(now())

  @@index([marketId, status])
  @@index([dedupHash])
}

enum ScrapedLeadStatus {
  PENDING
  APPROVED
  REJECTED
  DUPLICATE
}

// ─── Files ───────────────────────────────────────────────────────────

model File {
  id         String      @id @default(cuid())
  partnerId  String?
  partner    Partner?    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  folderId   String?
  folder     FileFolder? @relation(fields: [folderId], references: [id])
  uploaderId String
  name       String
  mimeType   String
  sizeBytes  Int
  storageKey String // R2 object key
  transcript String?     @db.Text // for voice notes
  virusScan  String      @default("pending") // pending / clean / infected
  createdAt  DateTime    @default(now())

  @@index([partnerId])
  @@index([folderId])
}

model FileFolder {
  id        String       @id @default(cuid())
  partnerId String
  name      String
  parentId  String?
  parent    FileFolder?  @relation("ChildFolders", fields: [parentId], references: [id])
  children  FileFolder[] @relation("ChildFolders")
  files     File[]
  createdAt DateTime     @default(now())

  @@index([partnerId])
}

// ─── Calendar ────────────────────────────────────────────────────────

model CalendarConnection {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              String // "google" / "apple" / "storm"
  externalAccountId     String
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  calendarIds           String[]
  lastSyncedAt          DateTime?
  syncStatus            String    @default("ok") // "ok" / "error" / "disconnected"
  syncError             String?

  @@index([userId])
}

model CalendarEventCache {
  id              String   @id @default(cuid())
  userId          String
  connectionId    String
  externalEventId String
  provider        String
  title           String
  location        String?
  startsAt        DateTime
  endsAt          DateTime
  lastSeenAt      DateTime @default(now())

  @@unique([userId, externalEventId, provider])
  @@index([userId, startsAt])
}

// ─── Notifications ───────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── Audit ───────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  /// Multi-tenant scope. Null for entries written before the multi-tenant
  /// retrofit (treated as belonging to the demo tenant); SUPER_ADMIN
  /// cross-tenant actions stay null intentionally so they're visible
  /// across tenant filters.
  tenantId   String?
  userId     String?
  entityType String
  entityId   String
  action     String
  diff       Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

// ─── Messaging templates & automation ────────────────────────────────

model MessageTemplate {
  id        String        @id @default(cuid())
  kind      MessageKind
  name      String
  subject   String? // email only
  body      String        @db.Text
  stage     PartnerStage?
  createdBy String
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([kind, active])
}

enum MessageKind {
  EMAIL
  SMS
}

model AutomationCadence {
  id           String       @id @default(cuid())
  name         String
  triggerStage PartnerStage
  steps        Json // [{ offsetHours, kind, templateId, requireApprovalBelowThreshold }]
  active       Boolean      @default(true)
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([triggerStage, active])
}

model CadenceExecution {
  id          String    @id @default(cuid())
  cadenceId   String
  partnerId   String
  stepIndex   Int
  scheduledAt DateTime
  executedAt  DateTime?
  outcome     String? // "sent" / "blocked_consent" / "blocked_quiet_hours" / "blocked_rate_limit" / "failed"

  @@index([partnerId, cadenceId])
  @@index([scheduledAt, executedAt])
}

model AIToneSample {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      MessageKind
  sample    String      @db.Text
  channel   String? // "email" / "sms" / "both"
  createdAt DateTime    @default(now())

  @@index([userId])
}

// ─── Feature flags (SPEC §7.10) ──────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  /// Per-user / per-market overrides stored as JSON: { users: string[], markets: string[] }
  overrides   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Phase 5 — Storm webhook log ─────────────────────────────────────
// (CalendarConnection + CalendarEventCache already exist above — they
// use a string `provider` column; Microsoft is just the string "microsoft".)

/// Raw log of inbound webhook deliveries (Storm for now). Kept for
/// forensics + replay; the admin Integrations page shows the last 20.
model WebhookEvent {
  id              String   @id @default(cuid())
  source          String // "STORM" / "RESEND" / "TWILIO" / ...
  externalEventId String   @unique
  eventType       String
  /// True when we validated the HMAC signature against the configured
  /// secret for this source; false when the secret was missing or the
  /// signature didn't match.
  verified        Boolean  @default(false)
  payload         Json
  createdAt       DateTime @default(now())

  @@index([source, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════
// EVENT TRACKING — see SPEC_EVENTS.md
// All Ev* tables group together so they can be audited / extracted as one.
// ═══════════════════════════════════════════════════════════════════════

model EvEvent {
  id                          String            @id @default(cuid())
  publicId                    String            @unique // "EV-1234" for display
  marketId                    String
  market                      Market            @relation(fields: [marketId], references: [id])
  name                        String
  description                 String?           @db.Text
  venueName                   String?
  venueAddress                String?
  venueLat                    Float?
  venueLng                    Float?
  startsAt                    DateTime
  endsAt                      DateTime
  timezone                    String
  status                      EvEventStatus     @default(DRAFT)
  visibility                  EvEventVisibility @default(PRIVATE)
  defaultPlusOnesAllowed      Boolean           @default(false)
  responseWindowOverride      Json?
  confirmationCascadeOverride Json?
  designId                    String?           // MwDesign
  emailSubject                String?
  smsBodyTemplate             String?
  createdBy                   String
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  canceledAt                  DateTime?
  canceledReason              String?
  /// Public read-only share token (SPEC_EVENTS §13 / EV-11). Nullable —
  /// we lazy-generate on first Share click so old events don't get
  /// spurious tokens.
  shareToken                  String?           @unique
  ticketTypes                 EvTicketType[]
  invites                     EvInvite[]
  hosts                       EvHost[]
  subEvents                   EvSubEvent[]
  reminders                   EvReminder[]
  activityLog                 EvActivityLogEntry[]
  batchOffers                 EvBatchOffer[]

  @@index([marketId, status])
  @@index([startsAt])
  @@index([createdBy])
}

enum EvEventStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELED
}

enum EvEventVisibility {
  PRIVATE
  MARKET_WIDE
  PUBLIC
  /// HOST_ONLY = only the event creator + assigned hosts can see/manage it.
  /// Admins + managers can still see it (they see everything in their market)
  /// but reps in the same market who AREN'T hosts get no visibility at all.
  /// Useful when Janessa wants to run her event without John seeing it.
  HOST_ONLY
}

model EvTicketType {
  id                 String               @id @default(cuid())
  eventId            String
  event              EvEvent              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name               String
  kind               EvTicketKind
  capacity           Int
  isPrimary          Boolean              @default(false)
  internalAllocation Int                  @default(0)
  description        String?
  createdAt          DateTime             @default(now())
  assignments        EvTicketAssignment[]
  subEvents          EvSubEvent[]
  batchOffers        EvBatchOffer[]

  @@unique([eventId, name])
  @@index([eventId])
}

enum EvTicketKind {
  PRIMARY
  DEPENDENT
}

model EvHost {
  id            String   @id @default(cuid())
  eventId       String
  event         EvEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation("EvHosts", fields: [userId], references: [id])
  ticketTypeIds Json     @default("[]")
  role          String?
  createdAt     DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

model EvSubEvent {
  id                    String          @id @default(cuid())
  eventId               String
  event                 EvEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind                  EvSubEventKind
  name                  String
  venueName             String?
  venueAddress          String?
  startsAt              DateTime
  endsAt                DateTime
  invitationScope       EvSubEventScope
  dependentTicketTypeId String?
  dependentTicketType   EvTicketType?   @relation(fields: [dependentTicketTypeId], references: [id])
  reminderOverride      Json?
  createdAt             DateTime        @default(now())

  @@index([eventId])
  @@index([startsAt])
}

enum EvSubEventKind {
  SETUP
  PRE_EVENT
  MAIN
  DINNER
  POST_EVENT
  TEARDOWN
  CUSTOM
}

enum EvSubEventScope {
  INTERNAL_ONLY
  ALL_CONFIRMED
  DEPENDENT_TICKET_HOLDERS
  CUSTOM
}

model EvInvite {
  id                      String               @id @default(cuid())
  eventId                 String
  event                   EvEvent              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partnerId               String?
  partner                 Partner?             @relation(fields: [partnerId], references: [id])
  contactId               String?
  adHocName               String?
  adHocEmail              String?
  adHocPhone              String?
  plusOneAllowed          Boolean              @default(false)
  plusOneName             String?
  queueOrder              Int
  queueTier               EvQueueTier          @default(PRIMARY)
  status                  EvInviteStatus       @default(QUEUED)
  sentAt                  DateTime?
  respondedAt             DateTime?
  confirmationRequestedAt DateTime?
  confirmedAt             DateTime?
  expiresAt               DateTime?
  canceledAt              DateTime?
  canceledReason          String?
  rsvpToken               String               @unique @default(cuid())
  lastEmailMessageId      String?
  lastSmsSid              String?
  notes                   String?              @db.Text
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  ticketAssignments       EvTicketAssignment[]
  rsvpEvents              EvRsvpEvent[]
  reminders               EvReminder[]
  batchOfferRecipients    EvBatchOfferRecipient[]

  @@unique([eventId, partnerId])
  @@index([eventId, status, queueOrder])
  @@index([partnerId])
  @@index([rsvpToken])
  @@index([expiresAt])
}

enum EvInviteStatus {
  QUEUED
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  CONFIRMATION_REQUESTED
  CONFIRMED
  NO_SHOW
  CANCELED
  AUTO_CANCELED
}

enum EvQueueTier {
  PRIMARY
  AUTO_FALLBACK
  AD_HOC
}

model EvTicketAssignment {
  id           String         @id @default(cuid())
  inviteId     String
  invite       EvInvite       @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  ticketTypeId String
  ticketType   EvTicketType   @relation(fields: [ticketTypeId], references: [id])
  quantity     Int            @default(1)
  status       EvTicketStatus @default(TENTATIVE)
  checkedInAt  DateTime?
  checkedInBy  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([inviteId, ticketTypeId])
  @@index([ticketTypeId, status])
}

enum EvTicketStatus {
  TENTATIVE
  CONFIRMED
  DROPPED
  RELEASED
}

model EvRsvpEvent {
  id          String   @id @default(cuid())
  inviteId    String
  invite      EvInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  kind        String
  ticketDelta Json?
  actorType   String
  actorId     String?
  userAgent   String?
  ipAddress   String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([inviteId, createdAt])
}

model EvReminder {
  id             String            @id @default(cuid())
  inviteId       String?
  invite         EvInvite?         @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  subEventId     String?
  eventId        String
  event          EvEvent           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  kind           EvReminderKind
  channel        EvReminderChannel
  scheduledFor   DateTime
  sentAt         DateTime?
  deliveryStatus String            @default("pending")
  messageId      String?
  createdAt      DateTime          @default(now())

  @@index([scheduledFor, sentAt])
  @@index([inviteId])
  @@index([eventId])
}

enum EvReminderKind {
  INITIAL_INVITE
  CONFIRMATION_REQUEST
  CONFIRMATION_NUDGE_1
  CONFIRMATION_NUDGE_2
  AUTO_CANCEL_NOTICE
  DAY_BEFORE
  ARRIVAL_DETAILS
  SETUP_T_MINUS_4H
  SETUP_T_MINUS_1H
  CUSTOM
}

enum EvReminderChannel {
  EMAIL
  SMS
  BOTH
}

model EvActivityLogEntry {
  id        String   @id @default(cuid())
  eventId   String
  event     EvEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String?
  kind      String
  summary   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventId, createdAt])
}

model EvWaitlistRule {
  id               String   @id @default(cuid())
  marketId         String   @unique
  market           Market   @relation(fields: [marketId], references: [id])
  active           Boolean  @default(true)
  orderingStrategy String   @default("priority-asc")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Batch-offer of a freed dependent ticket (SPEC_EVENTS §4.4).
/// One header per freed ticket; N recipients race to claim it.
model EvBatchOffer {
  id                String                  @id @default(cuid())
  eventId           String
  event             EvEvent                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId      String
  ticketType        EvTicketType            @relation(fields: [ticketTypeId], references: [id])
  status            EvBatchOfferStatus      @default(OPEN)
  expiresAt         DateTime
  claimedByInviteId String?
  claimedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  recipients        EvBatchOfferRecipient[]

  @@index([eventId, status])
  @@index([ticketTypeId, status])
  @@index([expiresAt])
}

enum EvBatchOfferStatus {
  OPEN
  CLAIMED
  EXPIRED
  CANCELED
}

model EvBatchOfferRecipient {
  id                String       @id @default(cuid())
  batchOfferId      String
  batchOffer        EvBatchOffer @relation(fields: [batchOfferId], references: [id], onDelete: Cascade)
  inviteId          String
  invite            EvInvite     @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  claimToken        String       @unique
  notifiedAt        DateTime?
  clickedAt         DateTime?
  wonRaceAt         DateTime?
  lostRaceAt        DateTime?
  wantsFutureOffers Boolean      @default(false)
  createdAt         DateTime     @default(now())

  @@unique([batchOfferId, inviteId])
  @@index([claimToken])
}

// ═══════════════════════════════════════════════════════════════════════
// MARKETING WIZARD — see SPEC_MARKETING.md
// All Mw* tables group together to stay extractable.
// ═══════════════════════════════════════════════════════════════════════

model MwWorkspace {
  id                       String              @id @default(cuid())
  /// Multi-tenant scope. Workspaces typically follow their market's tenant.
  tenantId                 String?
  tenant                   Tenant?             @relation(fields: [tenantId], references: [id])
  name                     String
  partnerRadarMarketId     String?             @unique
  market                   Market?             @relation(fields: [partnerRadarMarketId], references: [id])
  ownerUserId              String
  plan                     MwPlan              @default(EMBEDDED)
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  monthlyGenerationQuota   Int                 @default(25)
  monthlyGenerationsUsed   Int                 @default(0)
  quotaResetsAt            DateTime
  overageRatePerGeneration Decimal             @default(0.79) @db.Money
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  brands                   MwBrand[]
  designs                  MwDesign[]
  members                  MwWorkspaceMember[]
  socialAccounts           MwSocialAccount[]
  printJobs                MwPrintJob[]

  @@index([stripeCustomerId])
}

enum MwPlan {
  SEEDLING
  PRO
  AGENCY
  STUDIO
  ENTERPRISE
  TRIAL
  EMBEDDED
}

model MwWorkspaceMember {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   MwWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  role        MwWorkspaceRole @default(EDITOR)
  invitedBy   String?
  createdAt   DateTime        @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum MwWorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model MwBrand {
  id              String             @id @default(cuid())
  workspaceId     String
  workspace       MwWorkspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  profile         Json
  status          MwBrandStatus      @default(TRAINING)
  isDefault       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  trainingSamples MwTrainingSample[]
  designs         MwDesign[]
  logos           MwBrandAsset[]

  @@index([workspaceId])
}

enum MwBrandStatus {
  TRAINING
  ACTIVE
  ARCHIVED
}

model MwTrainingSample {
  id          String   @id @default(cuid())
  brandId     String
  brand       MwBrand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  fileId      String
  contentType String
  analysis    Json?
  createdAt   DateTime @default(now())

  @@index([brandId])
}

model MwBrandAsset {
  id        String           @id @default(cuid())
  brandId   String
  brand     MwBrand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  kind      MwBrandAssetKind
  variant   String?
  fileId    String
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([brandId])
}

enum MwBrandAssetKind {
  LOGO
  BADGE
  CERTIFICATION
  ICON
  CUSTOM
}

model MwDesign {
  id                    String            @id @default(cuid())
  workspaceId           String
  workspace             MwWorkspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandId               String
  brand                 MwBrand           @relation(fields: [brandId], references: [id])
  createdBy             String
  name                  String
  contentType           MwContentType
  templateId            String?
  status                MwDesignStatus    @default(DRAFT)
  intent                Json
  direction             Json
  document              Json
  previewImageUrl       String?
  partnerRadarEventId   String?
  partnerRadarPartnerId String?
  tags                  String[]
  archivedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  versions              MwDesignVersion[]
  exports               MwExport[]
  campaigns             MwCampaign[]

  @@index([workspaceId, status])
  @@index([brandId])
  @@index([partnerRadarEventId])
  @@index([createdBy])
}

enum MwDesignStatus {
  DRAFT
  REVIEW
  APPROVED
  FINAL
  ARCHIVED
}

enum MwContentType {
  FLYER
  SOCIAL_POST
  SOCIAL_STORY
  BROCHURE
  BUSINESS_CARD
  EMAIL_HEADER
  POSTCARD
}

model MwDesignVersion {
  id        String   @id @default(cuid())
  designId  String
  design    MwDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  document  Json
  changeLog String
  createdBy String
  createdAt DateTime @default(now())

  @@index([designId, createdAt])
}

model MwExport {
  id            String   @id @default(cuid())
  designId      String
  design        MwDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  format        String
  targetChannel String?
  width         Int
  height        Int
  dpi           Int?
  colorMode     String?
  fileId        String
  sizeBytes     Int
  createdAt     DateTime @default(now())

  @@index([designId])
}

model MwCampaign {
  id                  String           @id @default(cuid())
  workspaceId         String
  designId            String
  design              MwDesign         @relation(fields: [designId], references: [id], onDelete: Cascade)
  name                String
  channelMix          Json
  recipients          Json
  status              MwCampaignStatus @default(DRAFT)
  scheduledFor        DateTime?
  sentAt              DateTime?
  stats               Json?
  partnerRadarEventId String?
  createdBy           String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([workspaceId, status])
  @@index([partnerRadarEventId])
}

enum MwCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELED
}

model MwSocialAccount {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          MwWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId             String?
  platform           MwSocialPlatform
  externalId         String
  handle             String
  displayName        String?
  avatarUrl          String?
  providerAccountRef String
  connectionStatus   String           @default("active")
  connectedAt        DateTime         @default(now())
  lastPostedAt       DateTime?

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId, platform])
  @@index([userId])
}

enum MwSocialPlatform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  PINTEREST
  X
  TIKTOK
  YOUTUBE
  GOOGLE_BUSINESS
}

model MwGeneration {
  id           String   @id @default(cuid())
  workspaceId  String
  designId     String?
  userId       String
  model        String
  kind         String
  inputTokens  Int?
  outputTokens Int?
  durationMs   Int?
  costUsd      Decimal  @db.Money
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([model])
}

model MwPrintJob {
  id              String      @id @default(cuid())
  workspaceId     String
  workspace       MwWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  designId        String
  userId          String
  provider        String
  product         String
  quantity        Int
  shippingAddress Json
  orderCost       Decimal     @db.Money
  markupApplied   Decimal     @default(0) @db.Money
  externalOrderId String?
  status          String
  trackingUrl     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([workspaceId, status])
}
